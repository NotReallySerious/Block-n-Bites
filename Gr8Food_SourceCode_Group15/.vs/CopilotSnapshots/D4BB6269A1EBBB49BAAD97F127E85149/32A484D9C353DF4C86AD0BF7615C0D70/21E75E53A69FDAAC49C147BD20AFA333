        private void LoadAllSales()
        {
            var order = cmbSortOrder.SelectedItem?.ToString() == "Ascending" ? "ASC" : "DESC";
            var query = @"SELECT s.SaleID, s.SaleDate, p.ProductName, p.Category, c.Name AS ChefName, s.Quantity, s.Total
FROM Sales s
LEFT JOIN Products p ON s.ProductID = p.ProductID
LEFT JOIN Chefs c ON p.ChefID = c.ChefID
ORDER BY s.SaleDate " + order + ";";

            var dt = ExecuteQuery(query);
            if (dgvReport != null) dgvReport.DataSource = dt;
        }

        private void BtnSortByDate_Click(object sender, EventArgs e)
        {
            var input = txtFilterInput.Text.Trim();
            DateTime parsedDate;
            if (!DateTime.TryParseExact(input, new[] { "dd/MM/yyyy", "d/M/yyyy", "yyyy-MM-dd" }, CultureInfo.InvariantCulture, DateTimeStyles.None, out parsedDate))
            {
                MessageBox.Show("Invalid date format. Use dd/MM/yyyy", "Input Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var order = cmbSortOrder.SelectedItem?.ToString() == "Ascending" ? "ASC" : "DESC";
            var query = @"SELECT s.SaleID, s.SaleDate, p.ProductName, p.Category, c.Name AS ChefName, s.Quantity, s.Total
FROM Sales s
LEFT JOIN Products p ON s.ProductID = p.ProductID
LEFT JOIN Chefs c ON p.ChefID = c.ChefID
WHERE CAST(s.SaleDate AS date) = @SaleDate
ORDER BY s.SaleDate " + order + ";";

            var dt = ExecuteQuery(query, new Microsoft.Data.SqlClient.SqlParameter("@SaleDate", parsedDate.Date));
            dgvReport.DataSource = dt;
        }

        private void BtnSortByChef_Click(object sender, EventArgs e)
        {
            var input = txtFilterInput.Text.Trim();
            var order = cmbSortOrder.SelectedItem?.ToString() == "Ascending" ? "ASC" : "DESC";
            var query = @"SELECT s.SaleID, s.SaleDate, p.ProductName, p.Category, c.Name AS ChefName, s.Quantity, s.Total
FROM Sales s
LEFT JOIN Products p ON s.ProductID = p.ProductID
LEFT JOIN Chefs c ON p.ChefID = c.ChefID
WHERE (@ChefName = '' OR c.Name LIKE '%' + @ChefName + '%')
ORDER BY c.Name " + order + ", s.SaleDate DESC;";

            var dt = ExecuteQuery(query, new Microsoft.Data.SqlClient.SqlParameter("@ChefName", input));
            dgvReport.DataSource = dt;
        }

        private void BtnSortByCategory_Click(object sender, EventArgs e)
        {
            var input = txtFilterInput.Text.Trim();
            var order = cmbSortOrder.SelectedItem?.ToString() == "Ascending" ? "ASC" : "DESC";
            var query = @"SELECT s.SaleID, s.SaleDate, p.ProductName, p.Category, c.Name AS ChefName, s.Quantity, s.Total
FROM Sales s
LEFT JOIN Products p ON s.ProductID = p.ProductID
LEFT JOIN Chefs c ON p.ChefID = c.ChefID
WHERE (@Category = '' OR p.Category LIKE '%' + @Category + '%')
ORDER BY p.Category " + order + ", s.SaleDate DESC;";

            var dt = ExecuteQuery(query, new Microsoft.Data.SqlClient.SqlParameter("@Category", input));
            dgvReport.DataSource = dt;
        }

        private DataTable ExecuteQuery(string sql, params Microsoft.Data.SqlClient.SqlParameter[] parameters)
        {
            var dt = new DataTable();
            try
            {
                using var conn = new Microsoft.Data.SqlClient.SqlConnection(_connectionString);
                using var cmd = new Microsoft.Data.SqlClient.SqlCommand(sql, conn);
                if (parameters != null && parameters.Length > 0)
                    cmd.Parameters.AddRange(parameters);
                using var adapter = new Microsoft.Data.SqlClient.SqlDataAdapter(cmd);
                adapter.Fill(dt);
            }
            catch (Exception ex)
            {
                MessageBox.Show("Database query failed: " + ex.Message, "DB Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            return dt;
        }
