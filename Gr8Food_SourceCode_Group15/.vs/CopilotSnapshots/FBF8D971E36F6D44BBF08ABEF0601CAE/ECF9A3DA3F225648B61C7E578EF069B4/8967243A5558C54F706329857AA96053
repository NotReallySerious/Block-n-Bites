        // Read connection string from config for admin DB operations
        private readonly string _connectionString = System.Configuration.ConfigurationManager.ConnectionStrings["Gr8FoodConnection"]?.ConnectionString ?? throw new InvalidOperationException("Connection string 'Gr8FoodConnection' not found.");

        private DataGridView? dgvUsers;
